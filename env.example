# Optional legacy LiveKit credentials (get from https://cloud.livekit.io)
# Leave these blank if you use the primary local browser console.
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# API KEYS
# ---------------------------------------------------------------------------

# Sarvam AI (STT + TTS) — https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — required for the primary local browser chat and browser mic transcription
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Deepgram (STT) — https://console.deepgram.com
DEEPGRAM_API_KEY=

# Google Gemini (LLM) — https://aistudio.google.com/projects
GOOGLE_API_KEY=

# Groq (optional LLM) — https://console.groq.com
GROQ_API_KEY=

# Google Cloud STT (optional) — GCP service-account JSON path
GOOGLE_APPLICATION_CREDENTIALS=

# Supabase (optional) — https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

# ---------------------------------------------------------------------------
# F.R.I.D.A.Y. MARK IV — CORE SYSTEM
# ---------------------------------------------------------------------------

# File system paths
FRIDAY_WORKSPACE_DIR=workspace
FRIDAY_MEMORY_DIR=~/.friday_memory

# MCP Server
MCP_SERVER_URL=http://127.0.0.1:8000/sse
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_MOUNT_PATH=/
MCP_SSE_PATH=/sse
MCP_SESSION_TIMEOUT=30
FRIDAY_BROWSER_HEADLESS=0
# Keep extra integrations out of the critical startup path unless you explicitly want them.
FRIDAY_ENABLE_CALENDAR_TOOL=0
FRIDAY_DISABLED_TOOL_MODULES=

# Server identity (shown in MCP inspector)
SERVER_NAME=Friday
SERVER_INSTRUCTIONS=I am F.R.I.D.A.Y., a Tony Stark-style AI assistant. I have access to a comprehensive set of tools. Be concise, accurate, and a little witty.

# ---------------------------------------------------------------------------
# PROVIDER SELECTION
# ---------------------------------------------------------------------------
# The local browser mode (`uv run friday`) always uses OpenAI for chat and
# browser audio transcription today, so OPENAI_API_KEY is required there.
# These provider switches mainly affect the optional `uv run friday_voice` flow.

STT_PROVIDER=whisper        # local browser mic uses OpenAI; legacy voice also supports deepgram | sarvam | whisper
LLM_PROVIDER=openai         # local browser chat currently supports openai; legacy voice also supports gemini
TTS_PROVIDER=openai         # browser output uses speechSynthesis; legacy voice supports sarvam | openai

# ---------------------------------------------------------------------------
# STT MODELS
# ---------------------------------------------------------------------------

# Deepgram STT
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=en

# Sarvam STT
SARVAM_STT_MODEL=saaras:v3

# ---------------------------------------------------------------------------
# LLM MODELS
# ---------------------------------------------------------------------------

GEMINI_LLM_MODEL=gemini-2.5-flash
OPENAI_LLM_MODEL=gpt-4o
OPENAI_VISION_MODEL=

# ---------------------------------------------------------------------------
# TTS SETTINGS
# ---------------------------------------------------------------------------

TTS_SPEED=1.15

# Sarvam TTS
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SPEAKER=ishita

# OpenAI TTS
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ---------------------------------------------------------------------------
# AGENT PERSONA
# ---------------------------------------------------------------------------

# Customize the agent's opening greeting (what it says when you connect)
FRIDAY_GREETING=Greetings boss, you're awake late today. What are you up to?

# ---------------------------------------------------------------------------
# OPTIONAL: VS CODE CODEX RELAY
# ---------------------------------------------------------------------------

# Folder that relay mode should describe and open in VS Code by default.
# Leave blank to use the current server working directory.
FRIDAY_CODEX_PROJECT_DIR=.

# Override the VS Code executable if `code` is not on PATH.
FRIDAY_CODEX_VSCODE_EXECUTABLE=

# These are auto-detected from the installed OpenAI Codex extension package.json,
# but you can override them if your command labels differ.
FRIDAY_CODEX_OPEN_SIDEBAR_COMMAND=
FRIDAY_CODEX_NEW_THREAD_COMMAND=

# Include a local project snapshot before the spoken/typed request when dispatching to Codex.
FRIDAY_CODEX_INCLUDE_PROJECT_SNAPSHOT=true

# Optional extra instructions inserted before the user request in Codex relay mode.
FRIDAY_CODEX_PROMPT_PREAMBLE=

# Timing knobs for UI automation (milliseconds).
FRIDAY_CODEX_LAUNCH_WAIT_MS=1600
FRIDAY_CODEX_COMMAND_WAIT_MS=700

# ---------------------------------------------------------------------------
# SUBAGENT CONSTRAINTS
# ---------------------------------------------------------------------------

MAX_SUBAGENT_ITERATIONS=5

# Subagent Prompt Overrides (Optional)
# If set, these will completely replace the internal prompts for each task type.
# SUBAGENT_CODING_PROMPT=
# SUBAGENT_RESEARCH_PROMPT=
# SUBAGENT_WRITING_PROMPT=
# SUBAGENT_AUTO_PROMPT=

# ---------------------------------------------------------------------------
# EXECUTION TIMEOUTS (seconds)
# ---------------------------------------------------------------------------

PYTHON_EXEC_TIMEOUT=120
SHELL_EXEC_TIMEOUT=60
FRIDAY_MAX_TOOL_STEPS=8
FRIDAY_LOCAL_MAX_TOOL_ROUNDS=14
FRIDAY_LOCAL_MAX_OPENAI_TOOLS=64

# ---------------------------------------------------------------------------
# OPTIONAL: REAL WEB SEARCH (Brave Search API)
# ---------------------------------------------------------------------------
# Get a free key at: https://api.search.brave.com (2,000 queries/month free)
BRAVE_API_KEY=
